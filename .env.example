# Destiny local project configuration

# --- Model precedence ---
DESTINY_PRIMARY_MODEL=openai-codex/gpt-5.3-codex
DESTINY_FALLBACK_MODELS=openai-codex/gpt-5.2,openrouter/minimax/minimax-m2.5

# --- OpenAI OAuth (Codex-managed) ---
# destiny auth login openai will set these automatically
OPENAI_OAUTH_PROVIDER=codex
OPENAI_CODEX_AUTH_FILE=/home/your-user/.codex/auth.json

# --- API keys (optional; needed for direct provider probing/inference) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=
